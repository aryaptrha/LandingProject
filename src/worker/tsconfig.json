{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "composite": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@worker/*": ["./*"]
    },
    "tsBuildInfoFile": "../../node_modules/.tmp/tsconfig.worker.tsbuildinfo"
  },
  "include": ["./**/*.ts"]
}
